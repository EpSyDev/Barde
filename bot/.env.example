# Token du bot (Discord Developer Portal > Bot > Reset Token)
DISCORD_TOKEN=

# ID du serveur (clic droit sur le serveur > Copier l'identifiant)
# Optionnel : si renseigné, les commandes se synchronisent instantanément sur ce serveur.
GUILD_ID=

# Rôle autorisé à utiliser le panneau (en plus des administrateurs). Optionnel.
ADMIN_ROLE_ID=

# Les 4 salons vocaux (clic droit sur le salon > Copier l'identifiant)
CHANNEL_1=
CHANNEL_2=
CHANNEL_3=
CHANNEL_4=

# Nom personnalisé de chaque salon dans le panneau (optionnel)
CHANNEL_1_NAME=Salon 1
CHANNEL_2_NAME=Salon 2
CHANNEL_3_NAME=Salon 3
CHANNEL_4_NAME=Salon 4

# Chemin du binaire FFmpeg (laisser "ffmpeg" s'il est dans le PATH)
FFMPEG_PATH=ffmpeg
