# === 1 BOT PAR SALON ===
# Discord n'autorise qu'UNE connexion vocale par bot et par serveur.
# Pour jouer dans 4 salons en même temps, il faut donc 4 applications bot
# distinctes (4 tokens). Crée-les sur le Developer Portal (New Application
# > Bot > Reset Token) et invite chacune sur ton serveur (Connect + Speak).
#
# Le BOT 1 sert aussi de bot "panneau" : invite-le en plus avec le scope
# 'applications.commands' (c'est lui qui porte /panel).

# --- Salon 1 (bot principal / panneau) ---
TOKEN_1=
CHANNEL_1=
CHANNEL_1_NAME=Salon 1

# --- Salon 2 ---
TOKEN_2=
CHANNEL_2=
CHANNEL_2_NAME=Salon 2

# --- Salon 3 ---
TOKEN_3=
CHANNEL_3=
CHANNEL_3_NAME=Salon 3

# --- Salon 4 ---
TOKEN_4=
CHANNEL_4=
CHANNEL_4_NAME=Salon 4

# ID du serveur (clic droit sur l'icône du serveur > Copier l'identifiant).
# Recommandé : synchronise /panel instantanément.
GUILD_ID=

# Rôle autorisé à utiliser le panneau, en plus des admins. Optionnel.
ADMIN_ROLE_ID=

# Chemin du binaire FFmpeg (laisser "ffmpeg" : un binaire est embarqué en secours).
FFMPEG_PATH=ffmpeg

# Normaliser le volume au téléchargement (ré-encodage one-shot). 1 = oui, 0 = non.
NORMALIZE_AUDIO=1

# Nombre max de pistes importées d'une playlist YouTube d'un coup.
PLAYLIST_LIMIT=100
