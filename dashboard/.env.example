# --- API du bot (Tailscale Funnel) ---
API_BASE_URL=https://barde.tail2985e8.ts.net
API_TOKEN=le_meme_token_que_dans_le_.env_du_bot

# --- Discord OAuth (app d'un bot existant) ---
DISCORD_CLIENT_ID=xxxxxxxxxxxxxxxxx
DISCORD_CLIENT_SECRET=xxxxxxxxxxxxxxxxx

# IDs Discord autorisés à se connecter, séparés par des virgules (toi + le fonda)
ALLOWED_DISCORD_IDS=123456789012345678,987654321098765432

# --- Auth.js ---
# Généré avec: openssl rand -base64 32   (ou npx auth secret)
AUTH_SECRET=une_chaine_aleatoire_longue
# En prod Vercel, laisser vide (auto-détecté). En local: http://localhost:3000
# AUTH_URL=http://localhost:3000
